# Headers de cache para melhorar performance
# Compatível com Netlify, Cloudflare Pages e outros

# Fingerprinted Hugo resources are safe to cache permanently.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# Hugo-generated responsive variants are content-addressed.
/processed-images/*
  Cache-Control: public, max-age=31536000, immutable

# Stable editorial images must be revalidated.
/images/*
  Cache-Control: public, max-age=86400, must-revalidate

# Localized HTML, RSS, and search indexes share one unambiguous hourly policy.
/
  Cache-Control: public, max-age=3600, must-revalidate

/pt-br/*
  Cache-Control: public, max-age=3600, must-revalidate

/en/*
  Cache-Control: public, max-age=3600, must-revalidate

/*.html
  Cache-Control: public, max-age=3600, must-revalidate
