# Headers de cache para melhorar performance
# Compatível com Netlify, Cloudflare Pages e outros

# Fingerprinted Hugo resources are safe to cache permanently.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# Font filenames and editorial media are stable URLs and must be revalidated.
/fonts/*
  Cache-Control: public, max-age=86400, must-revalidate

# Stable editorial images and root-level icons must be revalidated.
/images/*
  Cache-Control: public, max-age=86400, must-revalidate

/*.ico
  Cache-Control: public, max-age=86400, must-revalidate

/*.png
  Cache-Control: public, max-age=86400, must-revalidate

/*.svg
  Cache-Control: public, max-age=86400, must-revalidate

/*.webmanifest
  Cache-Control: public, max-age=86400, must-revalidate

# Cache para HTML (mais curto para permitir atualizações)
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# Cache para JSON (index de busca)
/*.json
  Cache-Control: public, max-age=300, must-revalidate
